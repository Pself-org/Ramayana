{
  "name": "ramayana-odyssey",
  "version": "1.0.0",
  "description": "Ramayana Odyssey — Ancient Wisdom for Modern Life",
  "license": "MIT",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "drizzle-kit push && next build",
    "dev": "next dev --port 3001",
    "lint": "next lint",
    "start": "node server.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^0.511.0",
    "mysql2": "^3.11.4",
    "next": "15.4.11",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "resend": "^6.9.2",
    "sharp": "0.34.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  }
}
