# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST:5432/ramayana_odyssey_db

# ─── Payload CMS ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=your-strong-32-char-secret-here

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxx
RESEND_FROM_EMAIL=digest@ramayanaodyssey.com
RESEND_FROM_NAME=Ramayana Odyssey

# ─── Rate Limiting ────────────────────────────────────────────────────────────
SUBSCRIBE_RATE_LIMIT_MAX=5
SUBSCRIBE_RATE_LIMIT_WINDOW_MS=60000
